{
  "include": ["src/**/*.ts", "*.ts", ".env"], 
  "exclude": ["node_modules", "dist"],
  "compilerOptions": {
    "rootDir": "./",
    "outDir": "./dist",

    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "strict": true,
    "skipLibCheck": true,

    "esModuleInterop": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,

    "sourceMap": false,
    "declaration": false,
    "declarationMap": false,

    "moduleDetection": "force"
  }
}